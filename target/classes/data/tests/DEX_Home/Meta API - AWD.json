{
	"id": 115,
	"name": "Meta API - AWD",
	"endpoint": "intelligence/api/common/meta",
	"method": "GET",
	"headers": {
		"Accept": "application/intelligenceMeta.v1+json"
	},
	"suite": "DEX_Home",
	"path": "DEX_Home",
	"checks": [
		{
			"type": "patternMatch",
			"path": "rulesetId",
			"pattern": "^[0-9]{1,6}0[0-9]{11}$"
		},
		{
			"type": "fieldExistence",
			"path": "",
			"fields": [
				"rulesetId",
				"lastVisitedTarget",
				"extensionStatus"
			]
		},
		{
			"type": "valueMatch",
			"path": "initialDataPrepared",
			"expected": true
		},
		{
			"type": "valueMatch",
			"path": "isEIAgentInstalled",
			"expected": true
		}
	],
	"requires": [
		{
			"name": "lastVisitedProfileId",
			"path": "lastVisitedProfileId"
		},
		{
			"name": "remoteOfficeId",
			"path": "lastVisitedTarget.remoteOfficeId"
		}
	],
	"precheck": "Has Devices"
}